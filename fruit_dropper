local function createInput(labelText, configKey)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 25)
    row.BackgroundTransparency = 1
    row.Parent = MainFrame

    local lbl = createLabel(labelText, UDim2.new(0.6, 0, 1, 0))
    lbl.Parent = row

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.4, 0, 1, 0)
    box.Position = UDim2.new(0.6, 0, 0, 0)
    box.BackgroundColor3 = C.box
    box.TextColor3 = C.text
    box.Text = tostring(Config[configKey])
    box.Font = Enum.Font.Gotham
    box.TextSize = 13
    box.Parent = row
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)

    box.FocusLost:Connect(function()
        local val = tonumber(box.Text)
        if val then
            Config[configKey] = val
        else
            box.Text = tostring(Config[configKey])
        end
    end)
end

