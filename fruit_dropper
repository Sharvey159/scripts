local function addLog(msg)
    local lbl = createLabel("• " .. msg, UDim2.new(1, 0, 0, 18), Enum.Font.Gotham, C.muted)
    lbl.TextSize = 12
    lbl.Parent = LogScroll
    
    table.insert(state.logs, lbl)
    if #state.logs > 10 then
        local old = table.remove(state.logs, 1)
        old:Destroy()
    end
    LogScroll.CanvasSize = UDim2.new(0, 0, 0, LogLayout.AbsoluteContentSize.Y)
end

local function updateUI(currentItemName, currentItemValM)
    StatusState.Text = state.isRunning and "🟢 Running" or "🔴 Stopped"
    StatusState.TextColor3 = state.isRunning and C.success or C.danger
    
    if currentItemName then
        CurrentItemLbl.Text = currentItemName
        CurrentValLbl.Text = string.format("%.2fM", currentItemValM)
    end

    StatsLbl.Text = string.format("Scanned: %d\nQualified: %d\nDropped: %d/%d", state.scanned, state.qualified, state.dropped, Config.MaxDrops)
    
    local pct = math.clamp(state.dropped / Config.MaxDrops, 0, 1)
    ProgFill.Size = UDim2.new(pct, 0, 1, 0)
    ProgText.Text = math.floor(pct * 100) .. "%"
end

local function startAutoDrop()
    if state.isRunning then return end
    state.isRunning = true
    state.scanned = 0
    state.qualified = 0
    state.dropped = 0
    state.batchCount = 0
    updateUI("Scanning...", 0)
    addLog("Started dropping sequence.")

    task.spawn(function()
        while state.isRunning and state.dropped < Config.MaxDrops do
            local foundAndDroppedThisCycle = false
            local containers = {}
            
            if Config.ScanBackpack then table.insert(containers, lp:FindFirstChildOfClass("Backpack")) end
            if Config.ScanCharacter and lp.Character then table.insert(containers, lp.Character) end

            for _, container in ipairs(containers) do
                if not state.isRunning or state.dropped >= Config.MaxDrops then break end
                if not container then continue end

                for _, item in ipairs(container:GetChildren()) do
                    if not state.isRunning or state.dropped >= Config.MaxDrops then break end

                    if item:GetAttribute("HarvestedFruit") and item:GetAttribute("Id") then
                        state.scanned += 1
                        updateUI()

                        local isFav = item:GetAttribute("IsFavorite") or false
                        if Config.IgnoreFavorites and isFav then continue end

                        local id = item:GetAttribute("Id")
                        local itemName = item:GetAttribute("FruitName") or item.Name

                        local ok, result = pcall(function()
                            if Networking then return Networking.NPCS.GetFruitBid:Fire(id) end
                            return nil
                        end)

                        if ok and result then
                            local rawValue = (result.CurrentSellValue or result.CurrentOffer or result.BidPrice or 0)
                            local valueM = rawValue / 1000000

                            updateUI(itemName, valueM)

                            if valueM >= Config.MinValue and valueM <= Config.MaxValue then
                                state.qualified += 1
                                updateUI()
                                addLog("Promoting " .. itemName .. "...")

                                pcall(function()
                                    if Networking then Networking.Backpack.PromoteFruit:Fire(id) end
                                end)

                                local tool = nil
                                local startT = tick()
                                while tick() - startT < 3 and state.isRunning do
                                    local charTool = lp.Character and lp.Character:FindFirstChild(item.Name)
                                    local bpTool = lp:FindFirstChildOfClass("Backpack") and lp:FindFirstChildOfClass("Backpack"):FindFirstChild(item.Name)
                                    
                                    tool = charTool or bpTool
                                    if tool and tool:IsA("Tool") and not tool:GetAttribute("FruitProxy") then break end
                                    task.wait(0.1)
                                end

                                if tool then
                                    if tool.Parent ~= lp.Character then
                                        local humanoid = lp.Character:FindFirstChildOfClass("Humanoid")
                                        if humanoid then
                                            humanoid:EquipTool(tool)
                                            task.wait(0.5)
                                        end
                                    end

                                    pcall(function()
                                        if Networking then Networking.DroppedItem.RequestDrop:Fire("HarvestedFruits", id) end
                                    end)

                                    state.dropped += 1
                                    state.batchCount += 1
                                    foundAndDroppedThisCycle = true
                                    addLog(string.format("Dropped %s (%.2fM)", itemName, valueM))
                                    updateUI()
                                    
                                    if state.batchCount >= Config.BatchSize then
                                        CurrentItemLbl.Text = "Waiting for pickup..."
                                        addLog("Batch limit reached. Waiting for pickup...")
                                        local waitStart = tick()
                                        while state.isRunning and tick() - waitStart < 60 do
                                            local di = Workspace:FindFirstChild("DroppedItems")
                                            if di and #di:GetChildren() == 0 then break end
                                            task.wait(1)
                                        end
                                        state.batchCount = 0
                                    end

                                    break 
                                end
                            else
                                addLog(string.format("Skipped %s (%.2fM)", itemName, valueM))
                            end
                        end
                    end
                end
                if foundAndDroppedThisCycle then break end
            end

            if not foundAndDroppedThisCycle then
                task.wait(1) 
            end
        end

        state.isRunning = false
        updateUI("Finished", 0)
        addLog("Auto Drop Sequence Finished.")
    end)
end

